# CARLA environment variables
# Copy this file to .env and fill in the paths for your environment.
# Variables already exported in your shell take precedence over this file.

# Path to the CarlaUE5.sh launcher (required to start a managed CARLA server)
CARLA_UE5_EXECUTABLE=/opt/carla/CarlaUE5.sh

# Paths to built-in CARLA map .xodr files.
# Add one entry per map you use with load_map_by_overwriting_xodr().
# The variable name is derived from the CamelCase map name:
#   NishishinjukuMap -> NISHISHINJUKU_MAP_PATH
#   Town01           -> TOWN01_PATH
#   Town10HD_Opt     -> TOWN10_HD_OPT_PATH
NISHISHINJUKU_MAP_PATH=/opt/carla/CarlaUE5/Content/Carla/Maps/NishishinjukuMap.xodr
TOWN01_PATH=/opt/carla/CarlaUE5/Content/Carla/Maps/Town01.xodr
TOWN10_HD_OPT_PATH=/opt/carla/CarlaUE5/Content/Carla/Maps/Town10HD_Opt.xodr
